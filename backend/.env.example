# --- LLM ---
GEMINI_API_KEY=            # leave empty to use the offline advisor
GEMINI_MODEL=gemini-3.5-flash

# --- Firestore (leave empty to use local JSON store) ---
GOOGLE_APPLICATION_CREDENTIALS=       # path to service-account JSON (local dev)
FIREBASE_CREDENTIALS_JSON=            # OR the whole JSON inline (Render/hosted)
FIRESTORE_PROJECT_ID=
FIRESTORE_DATABASE=(default)

# --- Runtime ---
ENVIRONMENT=development
MODEL_DIR=../ml/models
CORS_ORIGINS=http://localhost:3000
