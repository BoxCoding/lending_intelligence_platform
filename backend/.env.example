# Copy to backend/.env for local development.

# --- LLM (optional; offline advisor works without it) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- Firestore (leave both empty to use the local JSON store instead) ---
GOOGLE_APPLICATION_CREDENTIALS=secrets/firebase-adminsdk.json
# FIREBASE_CREDENTIALS_JSON=   # inline JSON, used instead of the path above
                                # on hosted platforms (Vercel env vars) — see
                                # docs/DEPLOYMENT.md
FIRESTORE_PROJECT_ID=lendiq-dc313
FIRESTORE_DATABASE=(default)

# --- Runtime ---
ENVIRONMENT=development
MODEL_DIR=../ml/models          # local/Docker default; Vercel sets this to
                                 # "ml_models" (backend/ml_models/) instead —
                                 # see docs/DEPLOYMENT.md
CORS_ORIGINS=http://localhost:3000,https://*.vercel.app
